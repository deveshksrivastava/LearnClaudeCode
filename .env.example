# ── Azure OpenAI (preferred) ─────────────────────────────────────────────────
# Endpoint from: Azure Portal → your Azure OpenAI resource → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-key>
# Deployment name you created in Azure OpenAI Studio (e.g. gpt-4o, gpt-35-turbo)
AZURE_OPENAI_DEPLOYMENT=gpt-4o
# API version – use latest stable
AZURE_OPENAI_API_VERSION=2024-02-01

# ── OpenAI fallback (if Azure is not configured) ──────────────────────────────
# OPENAI_API_KEY=sk-...
