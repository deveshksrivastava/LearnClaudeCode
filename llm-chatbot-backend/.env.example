# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Template for all required environment variables
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your actual values in .env
#   3. NEVER commit .env to git — it contains secrets!
#
# WHY USE ENV VARS?
#   Hard-coding secrets (API keys) in code is a major security risk.
#   Environment variables keep secrets out of source code and git history.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI (Standard) ──────────────────────────────────────────────────────
# Use this if you are using OpenAI directly (api.openai.com)
OPENAI_API_KEY=sk-your-openai-key-here

# ── Azure OpenAI (Enterprise) ──────────────────────────────────────────────
# Use these if you are using Azure OpenAI Service instead of OpenAI directly
AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# ── Provider Selection ─────────────────────────────────────────────────────
# Set to "openai" or "azure" to choose which LLM provider to use
LLM_PROVIDER=openai

# ── LLM Behaviour ──────────────────────────────────────────────────────────
# temperature: 0.0 = deterministic/factual, 1.0 = creative/random
LLM_TEMPERATURE=0.7
# max_tokens: Maximum length of LLM response (1 token ≈ 0.75 words)
LLM_MAX_TOKENS=1024
# Which OpenAI model to use when LLM_PROVIDER=openai
OPENAI_MODEL_NAME=gpt-4o-mini
# Which embedding model to use
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# ── ChromaDB (Vector Database) ─────────────────────────────────────────────
# Where ChromaDB stores its data on disk (relative or absolute path)
CHROMA_PERSIST_PATH=./chroma_data
# The name of the collection (like a "table" in a vector database)
CHROMA_COLLECTION_NAME=chatbot_docs
# ChromaDB server host (when running as a separate service via docker-compose)
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── Application ────────────────────────────────────────────────────────────
APP_VERSION=1.0.0
LOG_LEVEL=INFO
# Port the FastAPI server listens on
APP_PORT=8000
